{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/things/manus-storage/(.*)", "dest": "/manus-storage/$1" },
    { "src": "/things/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/things/(.*)", "dest": "/index.html" },
    { "src": "/things", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
